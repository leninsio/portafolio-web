---
interface Props {
  title: string;
  description: string;
  tag: string;
  image: string;
  colSpan?: number;
}

const { title, description, tag, image, colSpan = 3 } = Astro.props;

// For the carousel, we use fixed widths instead of grid spans
---

<div class="flex-none w-[85vw] md:w-[450px] bento-card group flex flex-col gap-6 scroll-animate snap-center">
  <div class="space-y-3">
    <div class="flex justify-between items-center">
      <span class="text-[10px] font-bold uppercase tracking-widest text-electric-blue">{tag}</span>
      <div class="opacity-0 group-hover:opacity-100 transition-opacity">
        <svg class="w-5 h-5 text-[var(--text-primary)]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path d="M7 17L17 7M17 7H7M17 7V17" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"></path>
        </svg>
      </div>
    </div>
    <h3 class="text-2xl font-bold text-[var(--text-primary)] tracking-tight">{title}</h3>
    <p class="text-[var(--text-secondary)] text-sm leading-relaxed line-clamp-2">{description}</p>
  </div>
  
  <div class="relative aspect-video rounded-lg overflow-hidden border border-[var(--card-border)] bg-[var(--bg-main)]">
    <img 
      src={image} 
      alt={title} 
      class="w-full h-full object-cover grayscale opacity-50 group-hover:grayscale-0 group-hover:opacity-100 transition-all duration-500"
    />
  </div>
</div>
