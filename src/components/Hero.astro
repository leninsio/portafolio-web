---
---
<section class="py-10 md:py-24 px-6 max-w-6xl mx-auto scroll-animate overflow-hidden">
  <div class="flex flex-col md:grid md:grid-cols-12 gap-10 md:gap-16 items-center">
    
    {/* Photo Placeholder */}
    <div class="w-full max-w-[280px] md:max-w-none md:col-span-5 order-1 md:order-2 mx-auto md:mx-0">
      <div class="relative group">
        <div class="absolute -inset-4 bg-gradient-to-tr from-electric-blue/20 to-royal-purple/20 rounded-[40px] blur-2xl opacity-40 group-hover:opacity-100 transition-opacity duration-700"></div>
        <div class="relative aspect-square md:aspect-[4/5] bg-[var(--card-bg)] border-2 border-[var(--card-border)] rounded-[32px] overflow-hidden shadow-2xl transition-transform duration-500 group-hover:-rotate-1 group-hover:scale-[1.02]">
          <div class="w-full h-full flex flex-col items-center justify-center text-[var(--text-secondary)] bg-[var(--bg-main)]">
            <svg class="w-12 h-12 md:w-16 md:h-16 opacity-20" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"></path>
            </svg>
            <span class="mt-4 text-[10px] uppercase tracking-widest font-bold opacity-40">Photo</span>
          </div>
        </div>
        {/* Floating Specialty Badge - Balanced Pill Style */}
        <div class="absolute -bottom-4 -right-2 md:-bottom-6 md:-left-6 z-30 animate-float w-fit">
          <div class="relative group/badge w-fit">
            <div class="absolute inset-0 bg-electric-blue/20 blur-xl rounded-full"></div>
            
            <div class="relative flex items-center gap-3 bg-[var(--nav-bg)]/95 backdrop-blur-xl border border-electric-blue/30 p-1 pr-5 rounded-full shadow-2xl w-fit">
              <div class="w-10 h-10 rounded-full bg-electric-blue flex items-center justify-center text-xl shadow-[0_0_15px_rgba(59,130,246,0.5)] shrink-0">
                <span class="animate-pulse">🤖</span>
              </div>
              <div class="flex flex-col shrink-0">
                <span class="text-[8px] uppercase tracking-[0.15em] text-electric-blue font-black leading-none mb-0.5" data-i18n="hero.specialty">Specialty</span>
                <span class="text-sm font-bold text-[var(--text-primary)] whitespace-nowrap leading-none" data-i18n="hero.ai">AI Systems</span>
              </div>
            </div>
          </div>
        </div>
        </div>
        </div>

        {/* Text Content */}
    <div class="md:col-span-7 space-y-6 md:space-y-10 order-2 md:order-1 text-center md:text-left">
      <div class="inline-flex items-center gap-2 px-3 py-1 bg-neon-green/10 border border-neon-green/20 rounded-full mx-auto md:mx-0">
        <span class="relative flex h-2 w-2">
          <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-neon-green opacity-75"></span>
          <span class="relative inline-flex rounded-full h-2 w-2 bg-neon-green"></span>
        </span>
        <span class="text-[10px] uppercase tracking-wider font-medium text-neon-green" data-i18n="hero.status">
          Available for new projects
        </span>
      </div>

      <div class="space-y-4 md:space-y-6">
        <h1 class="text-4xl md:text-7xl lg:text-8xl font-bold text-gradient leading-[1.1] tracking-tight">
          <span data-i18n="hero.title">Hi, I'm Lenin.</span> <br/>
          <span class="text-[var(--text-secondary)]" data-i18n="hero.subtitle">I build intelligent products.</span>
        </h1>
        
        <p class="text-lg md:text-2xl text-[var(--text-secondary)] leading-relaxed max-w-2xl mx-auto md:mx-0" data-i18n="hero.description">
          Full Stack AI Developer & CS Student. Passionate about creating systems that solve real problems with precision.
        </p>
      </div>

      <div class="flex flex-col sm:flex-row gap-4 justify-center md:justify-start pt-4">
        <a href="#work" class="px-8 py-4 bg-[var(--text-primary)] text-[var(--bg-main)] font-bold rounded-xl hover:bg-electric-blue hover:text-white transition-all shadow-lg active:scale-95" data-i18n="hero.cta.work">
          Explore Work
        </a>
        <a href="#contact" class="px-8 py-4 bg-transparent border border-[var(--card-border)] text-[var(--text-primary)] font-bold rounded-xl hover:bg-[var(--card-bg)] transition-all active:scale-95" data-i18n="hero.cta.contact">
          Contact Me
        </a>
      </div>
    </div>

  </div>
</section>

<style>
  @keyframes float {
    0%, 100% { transform: translateY(0) rotate(0deg); }
    50% { transform: translateY(-10px) rotate(1deg); }
  }
  .animate-float {
    animation: float 5s ease-in-out infinite;
  }
</style>
