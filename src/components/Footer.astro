    <div class="flex gap-8">
      <a href="mailto:contact@example.com" class="text-xs uppercase tracking-widest text-[var(--text-secondary)] hover:text-[var(--text-primary)] transition-colors">Email</a>
      <a href="https://twitter.com" class="text-xs uppercase tracking-widest text-[var(--text-secondary)] hover:text-[var(--text-primary)] transition-colors">Twitter</a>
      <a href="https://github.com/leninsio" class="text-xs uppercase tracking-widest text-[var(--text-secondary)] hover:text-[var(--text-primary)] transition-colors">GitHub</a>
