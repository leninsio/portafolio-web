<footer class="mt-20 py-12 border-t border-[var(--card-border)]">
  <div class="max-w-[1200px] mx-auto px-4 flex flex-col md:flex-row justify-between items-center gap-8">
    <div class="space-y-2 text-center md:text-left">
      <h3 class="text-2xl font-bold text-[var(--text-primary)] tracking-tighter">Lenin Sio</h3>
      <p class="text-sm text-[var(--text-secondary)]" data-i18n="footer.description">Building the future of AI interfaces.</p>
